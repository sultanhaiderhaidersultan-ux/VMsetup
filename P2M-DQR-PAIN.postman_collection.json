		{
			"name": "p2m/outgoingService/initiateRTP",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"function generateRandomNumber(length) {\r",
							"    let result = '';\r",
							"    const characters = '0123456789';\r",
							"    for (let i = 0; i < length; i++) {\r",
							"        result += characters.charAt(Math.floor(Math.random() * characters.length));\r",
							"    }\r",
							"    return result;\r",
							"}\r",
							"\r",
							"function getFormattedDateTime(offsetHours = 0) {\r",
							"    const now = new Date();\r",
							"    now.setHours(now.getHours() + offsetHours);\r",
							"    return now.toISOString().replace(/\\.\\d{3}Z$/, '.000');\r",
							"}\r",
							"\r",
							"function getExpiryDateTime(offsetHours = 0) {\r",
							"    const now = new Date();\r",
							"    now.setHours(now.getHours() + offsetHours + 1);\r",
							"    return now.toISOString().replace(/\\.\\d{3}Z$/, '.000');\r",
							"}\r",
							"\r",
							"function generateGuid() {\r",
							"    return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {\r",
							"        const r = Math.random() * 16 | 0,\r",
							"              v = c === 'x' ? r : (r & 0x3 | 0x8);\r",
							"        return v.toString(16);\r",
							"    });\r",
							"}\r",
							"\r",
							"const timezoneOffset = +5;\r",
							"\r",
							"let requestBody = pm.request.body.raw;\r",
							"let iban = \"\";\r",
							"\r",
							"try {\r",
							"    let json = JSON.parse(requestBody);\r",
							"\r",
							"    if (json && json.Debitor && json.Debitor.IBAN) {\r",
							"        iban = json.Debitor.IBAN;\r",
							"        pm.environment.set(\"IBAN\", iban);\r",
							"    } else {\r",
							"        console.warn(\"⚠️ IBAN not found in request body.\");\r",
							"    }\r",
							"\r",
							"} catch (e) {\r",
							"    console.warn(\"⚠️ Failed to parse request body to extract IBAN:\", e);\r",
							"}\r",
							"\r",
							"// --- Extract IBAN Short Code ---\r",
							"let ibanShort = \"\";\r",
							"\r",
							"if (iban && iban.length >= 8) {\r",
							"    ibanShort = iban.substring(4, 8).toUpperCase();\r",
							"    pm.environment.set(\"IBANSHORT\", ibanShort);\r",
							"} else {\r",
							"    console.warn(\"⚠️ IBAN too short or missing, skipping IBANSHORT extraction.\");\r",
							"}\r",
							"\r",
							"// --- BIC Lookup Map ---\r",
							"const bicLookup = {\r",
							"    \"FMFB\": \"FMICFBPK\",\r",
							"    \"KHBL\": \"KHBLDFID\",\r",
							"    \"NBPF\": \"NBPBPKKA\",\r",
							"    \"NAYA\": \"NAYAPKKA\",\r",
							"    \"DUIB\": \"DUIBPKKA\",\r",
							"    \"SIND\": \"SINDPKKA\",\r",
							"    \"MCIB\": \"MCIBPKKI\",\r",
							"    \"UMBL\": \"UMBLPKKA\",\r",
							"    \"JCMA\": \"WMBLPKKA\",\r",
							"    \"UNIL\": \"UNILPKKARTG\",\r",
							"    \"MUCB\": \"MUCBPKKKRTG\",\r",
							"    \"ABPA\": \"ABPAPKKA\",\r",
							"    \"HABB\": \"HABBPKKARTG\",\r",
							"    \"FAYS\": \"FAYSPKKA\",\r",
							"    \"ASCM\": \"ASCMPKKA\",\r",
							"    \"SUMB\": \"AHRBPKKA\",\r",
							"    \"SAMB\": \"MBPLPKKA\",\r",
							"    \"BPUN\": \"BPUNPKKA\",\r",
							"    \"ALFH\": \"ALFHPKKA\",\r",
							"    \"BAHL\": \"BAHLPKKA\",\r",
							"    \"SCBL\": \"SCBLPKKA\",\r",
							"    \"MPBL\": \"MPBLPKKA\",\r",
							"    \"SAUD\": \"SAUDPKKA\",\r",
							"    \"KHYB\": \"KHYBPKKA\",\r",
							"    \"MEZN\": \"MEZNPKKA\",\r",
							"    \"FWOM\": \"FWOMPKKA\",\r",
							"    \"BKIP\": \"BKIPPKKA\",\r",
							"    \"TMFB\": \"TMICFBPK\",\r",
							"    \"AIIN\": \"EGIBPKKA\",\r",
							"    \"SONE\": \"SONEPKKA\",\r",
							"    \"NBPA\": \"NBPBPKKA\",\r",
							"    \"JSBL\": \"JSBLPKKA\",\r",
							"    \"SADA\": \"SADAPKKA\",\r",
							"    \"CDCP\": \"CDCAGRTR\",\r",
							"    \"CDNS\": \"FGCDNSER\",\r",
							"    \"ONEL\": \"ONELINKG\",\r",
							"    \"SBPD\": \"PMRFGLPK\",\r",
							"    \"NULL\": \"PPAYFAST\"\r",
							"};\r",
							"\r",
							"// --- Determine BIC based on IBAN short ---\r",
							"let bicValue = bicLookup[ibanShort] || \"UNKNOWN\";\r",
							"pm.environment.set(\"BIC\", bicValue);\r",
							"\r",
							"// --- Generate IDs and Dates ---\r",
							"const currentDateTime = getFormattedDateTime(timezoneOffset);\r",
							"const expiryDateTime = getExpiryDateTime(timezoneOffset);\r",
							"const bizMsgIdr = `JSBLPKKAPAIN013${generateRandomNumber(12)}`;\r",
							"const msgId = `${generateRandomNumber(20)}|P2M`;\r",
							"const pmtInfId = generateRandomNumber(15);\r",
							"const billRefrenceNumber = generateRandomNumber(13);\r",
							"const instructionID = generateRandomNumber(15);\r",
							"const endToEndId = generateRandomNumber(22);\r",
							"const uetr = generateGuid();\r",
							"\r",
							"// --- Store in Environment ---\r",
							"pm.environment.set(\"BizMsgIdr\", bizMsgIdr);\r",
							"pm.environment.set(\"CreditDateTime\", currentDateTime);\r",
							"pm.environment.set(\"MsgId\", msgId);\r",
							"pm.environment.set(\"PmtInfId\", pmtInfId);\r",
							"pm.environment.set(\"ReqdExecutionDateTime\", currentDateTime);\r",
							"pm.environment.set(\"ExpiryDateTime\", expiryDateTime);\r",
							"pm.environment.set(\"BillRefrenceNumber\", billRefrenceNumber);\r",
							"pm.environment.set(\"InstructionID\", instructionID);\r",
							"pm.environment.set(\"EndToEndId\", endToEndId);\r",
							"pm.environment.set(\"UETR\", uetr);\r",
							"\r",
							"// --- Logs ---\r",
							"/*\r",
							"console.log(\"✅ IBAN:\", iban);\r",
							"console.log(\"✅ IBANSHORT:\", ibanShort);\r",
							"console.log(\"✅ BIC:\", bicValue);\r",
							"console.log(\"✅ BizMsgIdr:\", bizMsgIdr);\r",
							"console.log(\"✅ MsgId:\", msgId);\r",
							"console.log(\"✅ PmtInfId:\", pmtInfId);\r",
							"console.log(\"✅ UETR:\", uetr);\r",
							"console.log(\"✅ STAN:\", uetr);\r",
							"*/"
						],
						"type": "text/javascript"
					}
				}
			],
